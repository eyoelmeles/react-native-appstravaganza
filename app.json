{
  "expo": {
    "name": "react-native-appstravaganza",
    "slug": "react-native-appstravaganza",
    "scheme": "react-native-appstravaganza",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Inter-Black.ttf",
            "./assets/fonts/Inter-BlackItalic.ttf",
            "./assets/fonts/Inter-Bold.ttf",
            "./assets/fonts/Inter-BoldItalic.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-MeduimItalic",
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-SemiBoldItalic.ttf",
            "./assets/fonts/Inter-Thin.ttf",
            "./assets/fonts/Inter-ThinItalic.ttf"
          ]
        }
      ],
      "expo-router"
    ]
  }
}
